<Window x:Class="HyperVMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hyper-V Replication Monitor" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <Grid>
        <TabControl>
            <!-- Dashboard Tab -->
            <TabItem Header="Dashboard" Padding="10">
                <Grid Background="White">
                    <StackPanel Orientation="Vertical" Margin="20">
                        <!-- Server Status Panel -->
                        <TextBlock Text="Szerver Státusz" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                        
                        <Grid Height="150" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Server 1 -->
                            <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Margin="0,0,10,0" Background="#FFFFFF">
                                <StackPanel Margin="15" VerticalAlignment="Center">
                                    <TextBlock Text="HMHUVG21MP01" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Text="10.8.248.40" FontSize="11" Foreground="#666666" Margin="0,5,0,0"/>
                                    <TextBlock x:Name="Server1Status" Text="Ellenőrzés..." FontSize="12" Margin="0,10,0,0" Foreground="#FF9800"/>
                                    <Button x:Name="Failover1Btn" Content="Failover" Width="120" Height="35" Margin="0,10,0,0" Background="#2196F3" Foreground="White" Click="Failover1_Click"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Server 2 -->
                            <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Background="#FFFFFF">
                                <StackPanel Margin="15" VerticalAlignment="Center">
                                    <TextBlock Text="HMHUVG21MP02" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Text="10.8.248.41" FontSize="11" Foreground="#666666" Margin="0,5,0,0"/>
                                    <TextBlock x:Name="Server2Status" Text="Ellenőrzés..." FontSize="12" Margin="0,10,0,0" Foreground="#FF9800"/>
                                    <Button x:Name="Failover2Btn" Content="Failover" Width="120" Height="35" Margin="0,10,0,0" Background="#2196F3" Foreground="White" Click="Failover2_Click"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        
                        <!-- VM Replication Status -->
                        <TextBlock Text="VM Replikációs Státusz" FontSize="16" FontWeight="Bold" Margin="0,20,0,15"/>
                        <DataGrid x:Name="VmStatusGrid" Height="250" AutoGenerateColumns="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="VM Név" Binding="{Binding VmName}" Width="200"/>
                                <DataGridTextColumn Header="Szerver" Binding="{Binding ServerName}" Width="150"/>
                                <DataGridTextColumn Header="Státusz" Binding="{Binding Status}" Width="150"/>
                                <DataGridTextColumn Header="Utolsó Szinkronizálás" Binding="{Binding LastSync}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Grid>
            </TabItem>
            
            <!-- History Tab -->
            <TabItem Header="Előzmények" Padding="10">
                <Grid Background="White">
                    <StackPanel Orientation="Vertical" Margin="20">
                        <TextBlock Text="Események Előzményei" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                        <DataGrid x:Name="HistoryGrid" Height="500" AutoGenerateColumns="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Idő" Binding="{Binding Timestamp}" Width="180"/>
                                <DataGridTextColumn Header="Szerver" Binding="{Binding ServerName}" Width="150"/>
                                <DataGridTextColumn Header="Esemény" Binding="{Binding EventType}" Width="120"/>
                                <DataGridTextColumn Header="Részletek" Binding="{Binding Details}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Grid>
            </TabItem>
            
            <!-- Settings Tab -->
            <TabItem Header="Beállítások" Padding="10">
                <Grid Background="White">
                    <StackPanel Orientation="Vertical" Margin="20">
                        <TextBlock Text="Szerver Hitelesítés" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>
                        
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="HMHUVG21MP01 (10.8.248.40)" FontWeight="Bold" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Label Width="100">Felhasználónév:</Label>
                                <TextBox x:Name="Server1User" Width="250" Padding="5"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Label Width="100">Jelszó:</Label>
                                <PasswordBox x:Name="Server1Pass" Width="250" Padding="5"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="HMHUVG21MP02 (10.8.248.41)" FontWeight="Bold" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Label Width="100">Felhasználónév:</Label>
                                <TextBox x:Name="Server2User" Width="250" Padding="5"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Label Width="100">Jelszó:</Label>
                                <PasswordBox x:Name="Server2Pass" Width="250" Padding="5"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <Button x:Name="SaveSettingsBtn" Content="Beállítások Mentése" Width="150" Height="40" Background="#4CAF50" Foreground="White" Click="SaveSettings_Click" Margin="0,0,10,0"/>
                            <Button x:Name="TestConnectionBtn" Content="Kapcsolat Tesztelése" Width="150" Height="40" Background="#2196F3" Foreground="White" Click="TestConnection_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
